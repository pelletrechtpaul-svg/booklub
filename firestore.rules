rules_version = '2';

// Simple open rules for a private book-club app: anyone with the link can
// read and edit the ranking. There's no login. This is fine for a small,
// trusted group — but the collection is world-writable, so don't put anything
// sensitive here. To lock it down later, add Firebase Auth and gate on
// `request.auth != null`.
service cloud.firestore {
  match /databases/{database}/documents {
    match /books/{bookId} {
      allow read, write: if true;
    }
  }
}
